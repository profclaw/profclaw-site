---
import GitHubIcon from './icons/GitHubIcon.astro';
const milestones = [
  {
    name: 'OpenClaw',
    date: 'Nov 2025',
    tagline: 'The Original',
    description: 'Started as Clawdbot by Peter Steinberger. Multi-provider, 22+ channels, companion apps. The one that started it all.',
    stats: '250K+ stars',
    lang: 'TypeScript',
    color: '#94A3B8',
    github: 'https://github.com/openclaw/openclaw',
    site: 'https://openclaw.ai',
    // Lobster/claw logo
    logo: '<svg viewBox="0 0 32 32" fill="none"><ellipse cx="16" cy="18" rx="10" ry="9" fill="currentColor" opacity="0.15"/><ellipse cx="16" cy="18" rx="10" ry="9" stroke="currentColor" stroke-width="1.5" fill="none"/><circle cx="13" cy="16" r="2" fill="currentColor"/><circle cx="19" cy="16" r="2" fill="currentColor"/><path d="M13 22c1 1.5 5 1.5 6 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/><path d="M10 10l-4-5M22 10l4-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="5.5" cy="4.5" r="2" fill="currentColor" opacity="0.3"/><circle cx="26.5" cy="4.5" r="2" fill="currentColor" opacity="0.3"/></svg>',
    icon: '<svg viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="currentColor" stroke-width="1.5"/><path d="M8 14s1.5 2 4 2 4-2 4-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="10" r="1.2" fill="currentColor"/><circle cx="15" cy="10" r="1.2" fill="currentColor"/></svg>',
  },
  {
    name: 'PicoClaw',
    date: 'Feb 2026',
    tagline: 'Ultra-Lightweight',
    description: 'Go-based agent under 10MB RAM. Runs on Raspberry Pi, RISC-V, old Android via Termux. Built in a single day.',
    stats: '23.7K stars',
    lang: 'Go',
    color: '#22c55e',
    github: 'https://github.com/sipeed/picoclaw',
    site: 'https://picoclaw.ai',
    // Tiny claw on a chip
    logo: '<svg viewBox="0 0 32 32" fill="none"><rect x="8" y="8" width="16" height="16" rx="3" fill="currentColor" opacity="0.12"/><rect x="8" y="8" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.3" fill="none"/><ellipse cx="16" cy="17" rx="5" ry="4" fill="currentColor" opacity="0.2"/><circle cx="14" cy="16" r="1.2" fill="currentColor"/><circle cx="18" cy="16" r="1.2" fill="currentColor"/><path d="M12 5v3m8-3v3M12 24v3m8-3v3M5 12h3m-3 8h3M24 12h3m-3 8h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>',
    icon: '<svg viewBox="0 0 24 24" fill="none"><rect x="6" y="3" width="12" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="17" r="1" fill="currentColor"/><line x1="9" y1="7" x2="15" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
  },
  {
    name: 'MimiClaw',
    date: 'Feb 2026',
    tagline: 'Embedded AI',
    description: 'Pure C on ESP32-S3. AI agent on a $5 chip, no OS required. Thumb-sized, USB-powered, talks via Telegram.',
    stats: '3.8K stars',
    lang: 'C',
    color: '#f59e0b',
    github: 'https://github.com/memovai/mimiclaw',
    site: 'https://mimiclaw.io',
    // Tiny claw face
    logo: '<svg viewBox="0 0 32 32" fill="none"><rect x="6" y="6" width="20" height="20" rx="6" fill="currentColor" opacity="0.12"/><rect x="6" y="6" width="20" height="20" rx="6" stroke="currentColor" stroke-width="1.3" fill="none"/><circle cx="13" cy="15" r="2" fill="currentColor"/><circle cx="19" cy="15" r="2" fill="currentColor"/><path d="M13 20c1 1 5 1 6 0" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/><path d="M16 6v-3M6 16h-3M26 16h3M16 26v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>',
    icon: '<svg viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 1v3m6-3v3M9 20v3m6-3v3M1 9h3m-3 6h3M20 9h3m-3 6h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>',
  },
  {
    name: 'profClaw',
    date: 'Mar 2026',
    tagline: 'Professional Grade',
    description: '72 tools, 22 channels, voice I/O, browser automation, plugin SDK, MCP native. Enterprise task orchestration.',
    stats: 'v2.0 shipped',
    lang: 'TypeScript',
    color: '#f43f5e',
    github: 'https://github.com/profclaw/profclaw',
    // Our mascot
    logo: '<svg viewBox="0 0 32 32" fill="none"><defs><linearGradient id="pc-tl" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fb7185"/><stop offset="100%" stop-color="#e11d48"/></linearGradient></defs><ellipse cx="16" cy="18" rx="10" ry="9" fill="url(#pc-tl)"/><circle cx="13" cy="16.5" r="2.5" fill="#fff"/><circle cx="19" cy="16.5" r="2.5" fill="#fff"/><circle cx="14" cy="16" r="1.4" fill="#4c0519"/><circle cx="20" cy="16" r="1.4" fill="#4c0519"/><circle cx="14.8" cy="15.2" r="0.6" fill="#fff"/><circle cx="20.8" cy="15.2" r="0.6" fill="#fff"/><path d="M14 22q2 2.5 4 0" stroke="#9f1239" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>',
    icon: '<svg viewBox="0 0 24 24" fill="none"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    current: true,
  },
];

const ecosystem = [
  { name: 'ZeroClaw', stars: '16K' },
  { name: 'NanoClaw', stars: '12K' },
  { name: 'IronClaw', stars: '11.8K' },
  { name: 'NemoClaw', stars: 'NVIDIA' },
];
---

<section id="claw-family" class="fade-in-section relative z-10 px-6 py-16 overflow-hidden">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent-bright);">
      Lineage
    </p>
    <h2 class="font-heading text-2xl sm:text-3xl font-[800] text-center mb-3" style="color: var(--text-primary); letter-spacing: -0.02em;">
      The Claw Family
    </h2>
    <p class="text-center text-sm mb-14 max-w-lg mx-auto" style="color: var(--text-secondary);">
      An open-source AI agent ecosystem. Four key milestones, each one sharper than the last.
    </p>

    <!-- ===== DESKTOP: 3-ROW ALTERNATING TIMELINE ===== -->
    <div class="tl hidden md:block">
      <div class="tl-ambient" aria-hidden="true"></div>

      <!-- ROW 1: Top cards (index 0 and 2) -->
      <div class="tl-row">
        {milestones.map((m, i) => (
          <div class={`tl-cell ${i % 2 === 0 ? '' : 'tl-cell-empty'}`} style={`--c: ${m.color};`} data-tl-idx={i}>
            {i % 2 === 0 && (
              <div class={`tl-card tl-card-top tl-stagger ${m.current ? 'is-current' : ''}`} data-tl-card={i}>
                <div class="tl-card-inner">
                  <div class="tl-accent-bar tl-accent-bottom"></div>
                  <div class="flex items-center gap-3 mb-2">
                    <div class="tl-logo" set:html={m.logo} />
                    <div>
                      <h3 class="font-heading font-[800] text-[0.95rem]" style={`color: ${m.current ? 'var(--c)' : 'var(--text-primary)'}; letter-spacing: -0.01em;`}>{m.name}</h3>
                      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.12em]" style="color: var(--text-muted);">{m.tagline}</p>
                    </div>
                    <span class="tl-lang ml-auto">{m.lang}</span>
                  </div>
                  <p class="text-[0.76rem] leading-relaxed mb-3" style="color: var(--text-secondary);">{m.description}</p>
                  <div class="flex items-center justify-between">
                    <span class="tl-stat"><span class="tl-stat-dot"></span>{m.stats}</span>
                    <div class="flex items-center gap-1.5">
                      {m.site && (
                        <a href={m.site} target="_blank" rel="noopener" class="tl-link" title="Website">
                          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        </a>
                      )}
                      <a href={m.github} target="_blank" rel="noopener" class="tl-link" title="GitHub">
                        <GitHubIcon class="w-3.5 h-3.5" />
                      </a>
                    </div>
                  </div>
                  {m.current && <div class="tl-live-badge"><span class="tl-live-dot"></span>Latest Release</div>}
                </div>
                <div class="tl-stem-down"></div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- ROW 2: Rail + Nodes -->
      <div class="tl-rail-row">
        <div class="tl-rail">
          <div class="tl-rail-bg"></div>
          <div class="tl-rail-fill"></div>
          <div class="tl-rail-shimmer"></div>
        </div>
        <div class="tl-nodes">
          {milestones.map((m, i) => (
            <div class={`tl-node-cell ${m.current ? 'is-current' : ''}`} style={`--c: ${m.color};`} data-tl-node={i}>
              <div class="tl-node">
                <div class="tl-node-icon" set:html={m.icon} />
              </div>
              {m.current && <div class="tl-ring"></div>}
              <span class={`tl-date ${i % 2 === 0 ? 'tl-date-below' : 'tl-date-above'}`}>{m.date}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- ROW 3: Bottom cards (index 1 and 3) -->
      <div class="tl-row">
        {milestones.map((m, i) => (
          <div class={`tl-cell ${i % 2 === 1 ? '' : 'tl-cell-empty'}`} style={`--c: ${m.color};`} data-tl-idx={i}>
            {i % 2 === 1 && (
              <div class={`tl-card tl-card-bottom tl-stagger ${m.current ? 'is-current' : ''}`} data-tl-card={i}>
                <div class="tl-stem-up"></div>
                <div class="tl-card-inner">
                  <div class="tl-accent-bar tl-accent-top"></div>
                  <div class="flex items-center gap-3 mb-2">
                    <div class="tl-logo" set:html={m.logo} />
                    <div>
                      <h3 class="font-heading font-[800] text-[0.95rem]" style={`color: ${m.current ? 'var(--c)' : 'var(--text-primary)'}; letter-spacing: -0.01em;`}>{m.name}</h3>
                      <p class="text-[0.6rem] font-semibold uppercase tracking-[0.12em]" style="color: var(--text-muted);">{m.tagline}</p>
                    </div>
                    <span class="tl-lang ml-auto">{m.lang}</span>
                  </div>
                  <p class="text-[0.76rem] leading-relaxed mb-3" style="color: var(--text-secondary);">{m.description}</p>
                  <div class="flex items-center justify-between">
                    <span class="tl-stat"><span class="tl-stat-dot"></span>{m.stats}</span>
                    <div class="flex items-center gap-1.5">
                      {m.site && (
                        <a href={m.site} target="_blank" rel="noopener" class="tl-link" title="Website">
                          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        </a>
                      )}
                      <a href={m.github} target="_blank" rel="noopener" class="tl-link" title="GitHub">
                        <GitHubIcon class="w-3.5 h-3.5" />
                      </a>
                    </div>
                  </div>
                  {m.current && <div class="tl-live-badge"><span class="tl-live-dot"></span>Latest Release</div>}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- ===== MOBILE VERTICAL TIMELINE ===== -->
    <div class="md:hidden">
      <div class="tl-v">
        {milestones.map((m, i) => (
          <div class={`tl-v-item ${m.current ? 'is-current' : ''}`} style={`--c: ${m.color};`}>
            <div class="tl-v-track">
              <div class="tl-v-node">
                <div class="tl-v-icon" set:html={m.icon} />
              </div>
              {i < milestones.length - 1 && <div class="tl-v-line"></div>}
            </div>
            <div class="tl-v-body">
              <div class="flex items-center gap-2.5 mb-1">
                <div class="tl-logo-sm" set:html={m.logo} />
                <span class="text-[0.65rem] font-mono font-semibold" style="color: var(--c);">{m.date}</span>
              </div>
              <h3 class="font-heading font-[800] text-base" style={`color: ${m.current ? 'var(--c)' : 'var(--text-primary)'};`}>
                {m.name}
                <span class="tl-lang ml-2">{m.lang}</span>
              </h3>
              <p class="text-[0.65rem] font-semibold uppercase tracking-[0.12em] mb-1" style="color: var(--text-muted);">{m.tagline}</p>
              <p class="text-[0.78rem] leading-relaxed mb-2" style="color: var(--text-secondary);">{m.description}</p>
              <div class="flex items-center gap-3">
                <span class="tl-stat"><span class="tl-stat-dot"></span>{m.stats}</span>
                <a href={m.github} target="_blank" rel="noopener" class="tl-link" title="GitHub">
                  <GitHubIcon class="w-3.5 h-3.5" />
                </a>
                {m.current && <span class="tl-live-inline"><span class="tl-live-dot"></span>Live</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ===== ECOSYSTEM PILLS ===== -->
    <div class="mt-10 text-center">
      <p class="text-[0.72rem] font-medium mb-3" style="color: var(--text-muted);">
        Also in the ecosystem
      </p>
      <div class="flex flex-wrap items-center justify-center gap-2">
        {ecosystem.map((e) => (
          <span class="eco-pill">
            <span class="font-semibold" style="color: var(--text-secondary);">{e.name}</span>
            <span class="eco-sep"></span>
            <span>{e.stars}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Card-to-node hover linking -->
<script is:inline>
  document.querySelectorAll('[data-tl-card]').forEach(card => {
    const idx = card.dataset.tlCard;
    const node = document.querySelector(`[data-tl-node="${idx}"]`);
    if (!node) return;
    card.addEventListener('mouseenter', () => node.classList.add('is-hovered'));
    card.addEventListener('mouseleave', () => node.classList.remove('is-hovered'));
  });
</script>

<style>
  /* ===== SHARED ===== */
  .tl-lang {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 500;
    padding: 1px 6px;
    border-radius: 4px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    white-space: nowrap;
    line-height: 1.5;
  }

  .tl-logo {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    color: var(--c);
  }

  .tl-logo-sm {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--c);
  }

  .tl-stat {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .tl-stat-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--c);
    flex-shrink: 0;
  }

  .tl-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .tl-link:hover {
    color: var(--text-primary);
    border-color: var(--c);
    background: color-mix(in srgb, var(--c) 8%, transparent);
    transform: translateY(-1px);
  }

  .tl-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 0.62rem;
    font-weight: 700;
    color: #f43f5e;
    background: rgba(244, 63, 94, 0.1);
    border: 1px solid rgba(244, 63, 94, 0.15);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .tl-live-inline {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.62rem;
    font-weight: 700;
    color: #f43f5e;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tl-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #f43f5e;
    animation: live-blink 1.5s ease-in-out infinite;
  }

  @keyframes live-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ===== DESKTOP 3-ROW LAYOUT ===== */
  .tl {
    position: relative;
  }

  /* Ambient background glow */
  .tl-ambient {
    position: absolute;
    inset: -40px -20px;
    background: radial-gradient(ellipse at 50% 50%, rgba(244, 63, 94, 0.04), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  :global(html[data-theme='light']) .tl-ambient {
    background: radial-gradient(ellipse at 50% 50%, rgba(244, 63, 94, 0.02), transparent 70%);
  }

  /* Row layout */
  .tl-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .tl-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Stagger animation */
  .tl-stagger {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.is-visible) .tl-stagger {
    opacity: 1;
    transform: translateY(0);
  }

  :global(.is-visible) .tl-stagger:nth-child(1) { transition-delay: 0.1s; }
  :global(.is-visible) .tl-stagger:nth-child(2) { transition-delay: 0.2s; }
  :global(.is-visible) .tl-stagger:nth-child(3) { transition-delay: 0.3s; }
  :global(.is-visible) .tl-stagger:nth-child(4) { transition-delay: 0.4s; }

  /* ---- Cards ---- */
  .tl-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .tl-card-inner {
    position: relative;
    width: 100%;
    padding: 14px;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    overflow: hidden;
    text-align: left;
  }

  .tl-card:hover .tl-card-inner {
    border-color: color-mix(in srgb, var(--c) 30%, transparent);
    box-shadow: 0 12px 40px color-mix(in srgb, var(--c) 10%, transparent);
  }

  .tl-card-top:hover .tl-card-inner { transform: translateY(-4px); }
  .tl-card-bottom:hover .tl-card-inner { transform: translateY(4px); }

  .tl-card.is-current .tl-card-inner {
    border-color: color-mix(in srgb, var(--c) 20%, transparent);
    background: color-mix(in srgb, var(--c) 3%, var(--bg-card));
  }

  .tl-accent-bar {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--c);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .tl-accent-bottom { bottom: 0; }
  .tl-accent-top { top: 0; }

  .tl-card:hover .tl-accent-bar,
  .tl-card.is-current .tl-accent-bar { opacity: 1; }
  .tl-card.is-current .tl-accent-bar { opacity: 0.7; height: 2.5px; }

  /* ---- Stems ---- */
  .tl-stem-down {
    width: 2px;
    height: 20px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--c) 35%, transparent), transparent);
    flex-shrink: 0;
    transition: opacity 0.3s ease;
  }

  .tl-stem-up {
    width: 2px;
    height: 20px;
    background: linear-gradient(0deg, color-mix(in srgb, var(--c) 35%, transparent), transparent);
    flex-shrink: 0;
    transition: opacity 0.3s ease;
  }

  .tl-card:hover .tl-stem-down,
  .tl-card:hover .tl-stem-up { opacity: 0.8; }

  /* ---- Rail row ---- */
  .tl-rail-row {
    position: relative;
    padding: 8px 0;
    z-index: 1;
  }

  .tl-rail {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 3px;
    transform: translateY(-50%);
    z-index: 0;
  }

  .tl-rail-bg {
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: var(--border-subtle);
  }

  .tl-rail-fill {
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: linear-gradient(90deg, #94A3B8, #22c55e 35%, #f59e0b 65%, #f43f5e);
    opacity: 0.45;
  }

  /* Shimmer effect traveling along the rail */
  .tl-rail-shimmer {
    position: absolute;
    top: -2px;
    left: -100%;
    width: 60%;
    height: 7px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    border-radius: 4px;
    animation: rail-shimmer 4s ease-in-out infinite;
  }

  @keyframes rail-shimmer {
    0% { left: -60%; }
    100% { left: 100%; }
  }

  /* ---- Nodes ---- */
  .tl-nodes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    position: relative;
    z-index: 1;
