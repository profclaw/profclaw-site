---
import TabbedTerminal from './TabbedTerminal.astro';
---

<section id="quickstart" class="fade-in-section relative z-10 px-6 py-16 max-w-4xl mx-auto">
  <p class="text-center text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent-bright);">
    Get Started
  </p>
  <h2 class="font-heading text-2xl sm:text-3xl font-[800] text-center mb-3" style="color: var(--text-primary); letter-spacing: -0.02em;">
    Up and running in 60 seconds
  </h2>
  <p class="text-center text-sm mb-10 max-w-md mx-auto" style="color: var(--text-secondary);">
    When we launch, one command does the rest. Here's what it'll look like.
  </p>

  <TabbedTerminal />

  <p class="text-center text-xs mt-6" style="color: var(--text-muted);">
    Works on macOS, Windows &amp; Linux. Requires Node.js 22+. <span style="color: var(--accent-bright);">Launching next week.</span>
  </p>
</section>
