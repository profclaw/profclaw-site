---
/**
 * Reusable profClaw mascot SVG component.
 *
 * Renders the mascot with 3D gradients, highlights, and properly
 * prefixed IDs for multiple instances on the same page.
 *
 * Usage:
 *   <Mascot />                          -- default "m" prefix
 *   <Mascot prefix="nav" class="w-7" /> -- nav-sized with unique IDs
 */
interface Props {
  /** ID prefix for SVG elements (default: "m"). Must be unique per page. */
  prefix?: string;
  /** Additional CSS classes on the SVG element */
  class?: string;
  /** Show drop shadow and glow (default: true) */
  glow?: boolean;
}

const { prefix: p = 'm', class: className = '', glow = true } = Astro.props;

const filterStyle = glow
  ? 'filter: drop-shadow(0 0 40px rgba(244,63,94,0.3)) drop-shadow(0 10px 25px rgba(0,0,0,0.35));'
  : '';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 100 100"
  id={`${p}-svg`}
  class={className}
  style={filterStyle}
  preserveAspectRatio="xMidYMid meet"
>
  <defs>
    <!-- 3D body: off-center radial = sphere illusion -->
    <radialGradient id={`${p}-body`} cx="0.4" cy="0.35" r="0.65">
      <stop offset="0%" stop-color="#fda4af" />
      <stop offset="30%" stop-color="#fb7185" />
      <stop offset="65%" stop-color="#f43f5e" />
      <stop offset="100%" stop-color="#be123c" />
    </radialGradient>
    <!-- Specular highlight -->
    <radialGradient id={`${p}-spec`} cx="0.42" cy="0.28" r="0.35">
      <stop offset="0%" stop-color="#fff" stop-opacity="0.4" />
      <stop offset="100%" stop-color="#fff" stop-opacity="0" />
    </radialGradient>
    <!-- Rim light -->
    <radialGradient id={`${p}-rim`} cx="0.5" cy="0.95" r="0.5">
      <stop offset="0%" stop-color="#fda4af" stop-opacity="0.2" />
      <stop offset="100%" stop-color="#fda4af" stop-opacity="0" />
    </radialGradient>
    <!-- Eye whites -->
    <radialGradient id={`${p}-eye-w`} cx="0.4" cy="0.3" r="0.6">
      <stop offset="0%" stop-color="#ffffff" />
      <stop offset="100%" stop-color="#e2e8f0" />
    </radialGradient>
    <!-- Pupil -->
    <radialGradient id={`${p}-pupil`} cx="0.35" cy="0.3" r="0.6">
      <stop offset="0%" stop-color="#1e293b" />
      <stop offset="100%" stop-color="#0f0318" />
    </radialGradient>
    <!-- Antenna tip glow -->
    <radialGradient id={`${p}-ant-glow`} cx="0.38" cy="0.3" r="0.55">
      <stop offset="0%" stop-color="#fecdd3" />
      <stop offset="55%" stop-color="#fda4af" />
      <stop offset="100%" stop-color="#fb7185" />
    </radialGradient>
    <!-- Claw gradient -->
    <linearGradient id={`${p}-claw-g`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#e11d48" />
      <stop offset="100%" stop-color="#9f1239" />
    </linearGradient>
    <!-- Ground shadow -->
    <radialGradient id={`${p}-shadow-g`}>
      <stop offset="0%" stop-color="#000" stop-opacity="0.18" />
      <stop offset="100%" stop-color="#000" stop-opacity="0" />
    </radialGradient>
  </defs>

  <!-- Ground shadow -->
  <ellipse id={`${p}-shadow`} cx="50" cy="87" rx="22" ry="4" fill={`url(#${p}-shadow-g)`} />

  <!-- Legs -->
  <rect x="39" y="73" width="8" height="10" rx="4" fill={`url(#${p}-claw-g)`} />
  <rect x="53" y="73" width="8" height="10" rx="4" fill={`url(#${p}-claw-g)`} />

  <!-- Left claw -->
  <g id={`${p}-claw-l`}>
    <ellipse cx="20" cy="54" rx="8" ry="6" fill={`url(#${p}-claw-g)`} />
    <ellipse cx="20" cy="52" rx="5" ry="3" fill="#e11d48" opacity="0.3" />
    <path d="M15,49 L20,54 L25,49" stroke="#4c0519" stroke-width="1.8" fill="none" stroke-linecap="round" />
  </g>

  <!-- Right claw -->
  <g id={`${p}-claw-r`}>
    <ellipse cx="80" cy="54" rx="8" ry="6" fill={`url(#${p}-claw-g)`} />
    <ellipse cx="80" cy="52" rx="5" ry="3" fill="#e11d48" opacity="0.3" />
    <path d="M75,49 L80,54 L85,49" stroke="#4c0519" stroke-width="1.8" fill="none" stroke-linecap="round" />
  </g>

  <!-- Body sphere -->
  <ellipse cx="50" cy="54" rx="24" ry="22" fill={`url(#${p}-body)`} />
  <!-- Specular highlight -->
  <ellipse cx="44" cy="44" rx="14" ry="12" fill={`url(#${p}-spec)`} />
  <!-- Rim light -->
  <ellipse cx="50" cy="68" rx="18" ry="8" fill={`url(#${p}-rim)`} />

  <!-- Cheek blush -->
  <circle cx="34" cy="59" r="4.5" fill="#fda4af" opacity="0.25" />
  <circle cx="66" cy="59" r="4.5" fill="#fda4af" opacity="0.25" />

  <!-- Left antenna -->
  <g id={`${p}-ant-l`}>
    <line x1="39" y1="34" x2="31" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
    <circle cx="30" cy="18" r="4.5" fill={`url(#${p}-ant-glow)`} />
    <circle cx="28.5" cy="16" r="1.8" fill="#fff" opacity="0.55" />
  </g>

  <!-- Right antenna -->
  <g id={`${p}-ant-r`}>
    <line x1="61" y1="34" x2="69" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
    <circle cx="70" cy="18" r="4.5" fill={`url(#${p}-ant-glow)`} />
    <circle cx="68.5" cy="16" r="1.8" fill="#fff" opacity="0.55" />
  </g>

  <!-- Eyes -->
  <g id={`${p}-eyes`}>
    <!-- Left eye -->
    <circle cx="43" cy="51" r="7.2" fill={`url(#${p}-eye-w)`} />
    <circle id={`${p}-pl`} cx="44.5" cy="50" r="3.8" fill={`url(#${p}-pupil)`} />
    <circle id={`${p}-hl`} cx="46" cy="48.5" r="1.6" fill="#fff" />
    <!-- Right eye -->
    <circle cx="57" cy="51" r="7.2" fill={`url(#${p}-eye-w)`} />
    <circle id={`${p}-pr`} cx="58.5" cy="50" r="3.8" fill={`url(#${p}-pupil)`} />
    <circle id={`${p}-hr`} cx="60" cy="48.5" r="1.6" fill="#fff" />
  </g>

  <!-- Smile -->
  <path d="M44,63 Q50,69 58,62" stroke="#9f1239" stroke-width="2" fill="none" stroke-linecap="round" />
</svg>
