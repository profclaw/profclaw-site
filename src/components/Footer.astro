---
import GitHubIcon from './icons/GitHubIcon.astro';
import XIcon from './icons/XIcon.astro';
const year = new Date().getFullYear();
---

<!-- Final CTA banner -->
<section class="fade-in-section relative z-10 px-6 py-16">
  <div class="cta-banner max-w-5xl mx-auto">
    <div class="cta-banner-glow"></div>
    <div class="relative z-10 text-center py-12 px-6">
      <h2 class="font-heading text-xl sm:text-2xl font-[800] mb-3" style="color: var(--text-primary); letter-spacing: -0.02em;">
        Your AI agent is almost ready
      </h2>
      <p class="text-sm mb-7 max-w-md mx-auto" style="color: var(--text-secondary);">
        Open source, local-first, zero hosting costs. Install with one command.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="https://github.com/profclaw/profclaw" target="_blank" rel="noopener" class="btn-primary">
          <GitHubIcon />
          Get Started
        </a>
        <a href="#features" class="btn-secondary">
          Explore Features
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative z-10" style="border-top: 1px solid var(--border-subtle);">
  <div class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <!-- Top row: logo + nav + socials -->
    <div class="flex flex-col items-center gap-6 mb-6">
      <a href="/" class="flex items-center gap-2.5 group">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="w-8 h-8 transition-transform duration-300 group-hover:scale-110">
          <defs>
            <linearGradient id="ft-g" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#fb7185" />
              <stop offset="100%" stop-color="#e11d48" />
            </linearGradient>
          </defs>
          <ellipse cx="50" cy="54" rx="24" ry="22" fill="url(#ft-g)" />
          <circle cx="43" cy="51" r="6.5" fill="#fff" />
          <circle cx="57" cy="51" r="6.5" fill="#fff" />
          <circle cx="44.5" cy="50" r="3.5" fill="#4c0519" />
          <circle cx="58.5" cy="50" r="3.5" fill="#4c0519" />
          <circle cx="46" cy="48.5" r="1.4" fill="#fff" />
          <circle cx="60" cy="48.5" r="1.4" fill="#fff" />
        </svg>
        <span class="font-heading font-[800] text-base" style="letter-spacing: -0.02em;">
          <span class="bg-gradient-to-br from-[#fb7185] to-[#e11d48] bg-clip-text text-transparent">prof</span><span style="color: var(--text-primary);">Claw</span>
        </span>
      </a>

      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="#features" class="footer-link">Features</a>
        <a href="#modes" class="footer-link">Deployment</a>
        <a href="#quickstart" class="footer-link">Quick Start</a>
        <a href="#opensource" class="footer-link">Open Source</a>
        <a href="https://docs.profclaw.ai" target="_blank" rel="noopener" class="footer-link">Docs</a>
        <a href="https://github.com/profclaw/swift-llama" target="_blank" rel="noopener" class="footer-link">swift-llama</a>
      </nav>

      <div class="flex items-center gap-2.5">
        <a href="https://github.com/profclaw/profclaw" target="_blank" rel="noopener" class="footer-social" aria-label="GitHub">
          <GitHubIcon />
        </a>
        <a href="https://x.com/profclaw" target="_blank" rel="noopener" class="footer-social" aria-label="Twitter">
          <XIcon />
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-[0.65rem] leading-relaxed text-center max-w-lg mx-auto mb-6" style="color: var(--text-muted); opacity: 0.65;">
      Inspired by <a href="https://github.com/open-webui/open-webui" target="_blank" rel="noopener" class="footer-link" style="color: var(--text-secondary);">OpenClaw</a> and the open-source AI community. We saw the features that could be built and rebuilt them into a lighter, smarter, integration-ready engine.
    </p>

    <!-- Bottom bar -->
    <div class="pt-5 flex flex-col items-center gap-2" style="border-top: 1px solid var(--border-subtle);">
      <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-4">
        <p class="text-[0.7rem]" style="color: var(--text-muted);">
          &copy; {year} profClaw. AGPL-3.0 Licensed.
        </p>
        <span class="hidden sm:inline text-[0.7rem]" style="color: var(--text-muted);">&middot;</span>
        <p class="text-[0.7rem]" style="color: var(--text-muted);">
          Made with <span style="color: var(--accent-bright);">&#9829;</span> for people who own their stack.
        </p>
      </div>
      <p class="text-[0.6rem]" style="color: var(--text-muted); opacity: 0.5;">
        Maintained by <a href="https://glincker.com" target="_blank" rel="noopener" class="footer-link" style="color: var(--text-secondary);">GLINR Studios</a> &middot; <a href="https://glincker.com" target="_blank" rel="noopener" class="footer-link" style="color: var(--text-secondary);">glincker</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .cta-banner {
    position: relative;
    border-radius: 20px;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    backdrop-filter: blur(var(--glass-blur)) var(--glass-saturate);
    -webkit-backdrop-filter: blur(var(--glass-blur)) var(--glass-saturate);
    overflow: hidden;
  }

  .cta-banner-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(244, 63, 94, 0.08), transparent 60%);
    pointer-events: none;
  }

  :global(html[data-theme='light']) .cta-banner-glow {
    background: radial-gradient(ellipse at 50% 0%, rgba(244, 63, 94, 0.04), transparent 60%);
  }

  .footer-link {
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .footer-social:hover {
    color: var(--text-primary);
    border-color: var(--border-accent);
    transform: translateY(-1px);
    background: var(--bg-card);
  }
</style>
