---
const features = [
  {
    title: 'AGPL-3.0 Licensed',
    description: 'Fork it, modify it, ship it.',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
    accent: '#fb7185',
  },
  {
    title: 'Zero Telemetry',
    description: 'No tracking. No analytics. Ever.',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>',
    accent: '#a78bfa',
  },
  {
    title: 'No Cloud Required',
    description: 'Runs entirely on your hardware.',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>',
    accent: '#38bdf8',
  },
  {
    title: 'Data Stays Local',
    description: 'Your keys and conversations stay put.',
    svg: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    accent: '#34d399',
  },
];
---

<section id="opensource" class="fade-in-section relative z-10 px-6 py-16">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- LEFT: Text + CTA -->
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase mb-3" style="color: var(--accent-bright);">
          Open Source
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl font-[800] mb-3" style="color: var(--text-primary); letter-spacing: -0.02em;">
          Your code, your data, your rules
        </h2>
        <p class="text-sm mb-8 max-w-md" style="color: var(--text-secondary);">
          profClaw is fully open source under AGPL-3.0. No SaaS lock-in, no cloud dependency, no data exfiltration. Self-host and own every byte.
        </p>
        <span class="btn-primary" style="cursor: default; opacity: 0.9;">
          <svg class="w-4.5 h-4.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg>
          GitHub Repo Coming Soon
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </span>
      </div>

      <!-- RIGHT: 2x2 grid -->
      <div class="grid grid-cols-2 gap-3">
        {features.map((f) => (
          <div class="card p-5 group">
            <div class="relative z-10">
              <div class="mb-2.5 w-9 h-9 flex items-center justify-center rounded-xl" style={`color: ${f.accent}; background: ${f.accent}12; border: 1px solid ${f.accent}15;`}>
                <div class="w-[18px] h-[18px]" set:html={f.svg} />
              </div>
              <h3 class="font-heading font-bold text-[0.85rem] mb-1" style="color: var(--text-primary);">{f.title}</h3>
              <p class="text-[0.78rem] leading-relaxed" style="color: var(--text-muted);">{f.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
