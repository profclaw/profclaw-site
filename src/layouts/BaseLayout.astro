---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'profClaw - Smart, lightweight AI agent engine. Run locally on anything.',
} = Astro.props;

const canonicalUrl = 'https://profclaw.ai/';
const ogImage = 'https://profclaw.ai/og-image.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'profClaw',
  applicationCategory: 'UtilitiesApplication',
  applicationSubCategory: 'AI Agent Engine',
  operatingSystem: 'macOS, Windows, Linux, Docker',
  description: 'Smart, lightweight AI agent engine. Run locally on Docker, VPS, home PC, or Mac. Connect to Slack, Discord, Telegram and 22+ chat channels.',
  url: canonicalUrl,
  image: ogImage,
  screenshot: ogImage,
  softwareVersion: '1.0.0',
  datePublished: '2026-03-19',
  releaseNotes: 'Initial public release with 65+ tools, 22+ chat channels, 15+ AI providers, and 3 deployment modes.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/PreOrder',
  },
  license: 'https://opensource.org/licenses/AGPL-3.0',
  author: {
    '@type': 'Organization',
    name: 'profClaw',
    url: canonicalUrl,
    parentOrganization: {
      '@type': 'Organization',
      name: 'GLINR Studios',
      alternateName: 'glincker',
      url: 'https://glincker.com',
    },
    sameAs: [
      'https://github.com/profclaw/profclaw',
      'https://x.com/profclaw',
    ],
  },
  featureList: '15+ AI Providers, 22+ Chat Channels, 65+ Built-in Tools, MCP Native, Voice I/O, Browser Automation, Plugin SDK, Cost Tracking',
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="profClaw" />
    <meta name="keywords" content="AI agent, local AI, agent engine, MCP, Slack bot, Discord bot, Telegram bot, self-hosted AI, open source AI, AI assistant, AI copilot, private AI, on-premise AI, voice AI, browser automation, task automation" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/svg+xml" href="/brand/profclaw-favicon-coral-bg.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="mask-icon" href="/brand/safari-pinned-tab.svg" color="#f43f5e" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#050810" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbff" media="(prefers-color-scheme: light)" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="profClaw - Smart, lightweight AI agent engine. Mascot logo with coral gradient on dark background." />
    <meta property="og:site_name" content="profClaw" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@profclaw" />
    <meta name="twitter:creator" content="@profclaw" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="profClaw - Smart, lightweight AI agent engine" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Fonts - preload critical -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{title}</title>

    <!-- Prevent flash: apply saved theme immediately -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('pc-theme');
        const theme = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <!-- Deep Space Parallax: 3 star layers + shooting stars + nebula + grid + noise -->
    <div class="stars-far" data-parallax="0.02"></div>
    <div class="stars-mid" data-parallax="0.05"></div>
    <div class="stars-near" data-parallax="0.08"></div>
    <div class="shooting-stars" aria-hidden="true">
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
      <div class="shooting-star"></div>
    </div>
    <div class="nebula"></div>
    <div class="grid-overlay"></div>
    <div class="noise"></div>

    <!-- Sticky mascot nav (appears on scroll) -->
    <a href="#" class="sticky-mascot" id="sticky-mascot" aria-label="Back to top">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
        <defs>
          <radialGradient id="sm-g" cx="0.4" cy="0.35" r="0.65">
            <stop offset="0%" stop-color="#fda4af" />
            <stop offset="30%" stop-color="#fb7185" />
            <stop offset="65%" stop-color="#f43f5e" />
            <stop offset="100%" stop-color="#be123c" />
          </radialGradient>
        </defs>
        <ellipse cx="50" cy="54" rx="24" ry="22" fill="url(#sm-g)" />
        <ellipse cx="44" cy="44" rx="14" ry="12" fill="#fff" opacity="0.12" />
        <ellipse cx="20" cy="54" rx="8" ry="6" fill="#be123c" />
        <ellipse cx="80" cy="54" rx="8" ry="6" fill="#be123c" />
        <rect x="39" y="73" width="8" height="10" rx="4" fill="#be123c" />
        <rect x="53" y="73" width="8" height="10" rx="4" fill="#be123c" />
        <circle cx="43" cy="51" r="7" fill="#fff" />
        <circle cx="57" cy="51" r="7" fill="#fff" />
        <circle cx="44.5" cy="50" r="3.8" fill="#0f0318" />
        <circle cx="58.5" cy="50" r="3.8" fill="#0f0318" />
        <circle cx="46" cy="48.5" r="1.5" fill="#fff" />
        <circle cx="60" cy="48.5" r="1.5" fill="#fff" />
        <line x1="39" y1="34" x2="31" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
        <circle cx="30" cy="18" r="4" fill="#fda4af" />
        <line x1="61" y1="34" x2="69" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
        <circle cx="70" cy="18" r="4" fill="#fda4af" />
        <path d="M44,63 Q50,69 58,62" stroke="#9f1239" stroke-width="2" fill="none" stroke-linecap="round" />
      </svg>
      <span class="sticky-mascot-text">
        <span class="prof">prof</span><span class="claw">Claw</span>
      </span>
    </a>

    <!-- Theme toggle -->
    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
      <span class="theme-toggle-icon" data-theme-icon aria-hidden="true"></span>
    </button>

    <slot />

    <!-- Theme toggle + scroll observer -->
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');
        const icon = document.querySelector('[data-theme-icon]');
        if (!toggle || !icon) return;

        const applyTheme = (theme, save) => {
          root.dataset.theme = theme;
          root.style.colorScheme = theme;
          icon.textContent = theme === 'dark' ? '\u2600' : '\u263E';
          toggle.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
          if (save) localStorage.setItem('pc-theme', theme);
        };

        toggle.addEventListener('click', () => {
          applyTheme(root.dataset.theme === 'light' ? 'dark' : 'light', true);
        });

        applyTheme(root.dataset.theme || 'dark', false);
      })();

      // Parallax star layers
      (() => {
        const layers = document.querySelectorAll('[data-parallax]');
        if (!layers.length) return;
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = window.scrollY;
            layers.forEach((el) => {
              const speed = parseFloat(el.dataset.parallax) || 0;
              el.style.transform = 'translateY(' + (y * speed) + 'px)';
            });
            ticking = false;
          });
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      })();

      // Scroll fade-in with staggered child support
      const obs = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('is-visible'); }),
        { threshold: 0.05, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.fade-in-section').forEach((el) => obs.observe(el));

      // Sticky mascot
      (() => {
        const hero = document.getElementById('hero');
        const stickyMascot = document.getElementById('sticky-mascot');
        if (!hero || !stickyMascot) return;

        const heroObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                stickyMascot.classList.remove('is-visible');
              } else {
                stickyMascot.classList.add('is-visible');
              }
            });
          },
          { threshold: 0.15 }
        );
        heroObs.observe(hero);

        stickyMascot.addEventListener('click', (e) => {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
  </body>
</html>
