---
// OG Image page - screenshot at 1200x630 to generate og-image.png
// Usage: open http://localhost:6001/og in browser, screenshot at exactly 1200x630
---

<html>
  <head>
    <meta charset="UTF-8" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Manrope:wght@500;600&family=JetBrains+Mono:wght@500&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        width: 1200px;
        height: 630px;
        overflow: hidden;
        background: #050810;
        font-family: 'Manrope', system-ui, sans-serif;
        position: relative;
      }

      /* Background effects */
      .bg-glow-1 {
        position: absolute;
        width: 700px;
        height: 700px;
        top: -200px;
        left: -100px;
        background: radial-gradient(circle, rgba(244, 63, 94, 0.15), transparent 60%);
        filter: blur(80px);
      }

      .bg-glow-2 {
        position: absolute;
        width: 500px;
        height: 500px;
        bottom: -150px;
        right: -50px;
        background: radial-gradient(circle, rgba(139, 92, 246, 0.1), transparent 60%);
        filter: blur(80px);
      }

      /* Grid overlay */
      .grid-bg {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(136, 146, 176, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(136, 146, 176, 0.05) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse at 50% 40%, black 20%, transparent 70%);
      }

      /* Stars */
      .stars {
        position: absolute;
        inset: 0;
        background-image:
          radial-gradient(1.2px 1.2px at 80px 60px, rgba(255,255,255,0.5), transparent),
          radial-gradient(1px 1px at 200px 150px, rgba(255,255,255,0.35), transparent),
          radial-gradient(1.5px 1.5px at 350px 80px, rgba(251,113,133,0.4), transparent),
          radial-gradient(1px 1px at 500px 200px, rgba(255,255,255,0.3), transparent),
          radial-gradient(1.3px 1.3px at 700px 120px, rgba(255,255,255,0.4), transparent),
          radial-gradient(1px 1px at 900px 90px, rgba(167,139,250,0.35), transparent),
          radial-gradient(1.2px 1.2px at 1050px 180px, rgba(255,255,255,0.3), transparent),
          radial-gradient(0.8px 0.8px at 150px 400px, rgba(255,255,255,0.25), transparent),
          radial-gradient(1px 1px at 450px 350px, rgba(251,113,133,0.3), transparent),
          radial-gradient(0.8px 0.8px at 800px 450px, rgba(255,255,255,0.2), transparent),
          radial-gradient(1px 1px at 1100px 380px, rgba(255,255,255,0.3), transparent);
      }

      .content {
        position: relative;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        padding: 60px 80px;
        gap: 60px;
      }

      .left {
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        color: #fb7185;
        background: rgba(244, 63, 94, 0.12);
        border: 1px solid rgba(244, 63, 94, 0.25);
        margin-bottom: 24px;
        width: fit-content;
      }

      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fb7185;
      }

      .wordmark {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        font-weight: 800;
        font-size: 72px;
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: 8px;
      }

      .wordmark .prof {
        background: linear-gradient(135deg, #fb7185, #e11d48);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .wordmark .claw {
        color: #f0f4ff;
      }

      .tagline-sub {
        font-size: 13px;
        color: #5a6480;
        letter-spacing: 0.04em;
        margin-bottom: 20px;
      }

      .tagline-sub em {
        color: #fb7185;
        font-style: italic;
      }

      .tagline-sub span {
        color: #8892b0;
      }

      .subtitle {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #fb7185;
        margin-bottom: 16px;
      }

      .description {
        font-size: 20px;
        line-height: 1.5;
        color: #8892b0;
        max-width: 480px;
      }

      .stats {
        display: flex;
        gap: 10px;
        margin-top: 28px;
      }

      .stat {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(136, 146, 176, 0.12);
        font-size: 13px;
        font-weight: 600;
        color: #8892b0;
      }

      .stat-num {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px 8px;
        border-radius: 6px;
        background: linear-gradient(135deg, rgba(251, 113, 133, 0.2), rgba(225, 29, 72, 0.15));
        color: #fb7185;
        font-weight: 800;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
      }

      .right {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }

      .mascot-container {
        width: 220px;
        height: 220px;
        filter: drop-shadow(0 0 60px rgba(244, 63, 94, 0.3)) drop-shadow(0 12px 30px rgba(0, 0, 0, 0.4));
      }

      .domain {
        position: absolute;
        bottom: 36px;
        right: 80px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        font-weight: 500;
        color: #5a6480;
        letter-spacing: 0.02em;
      }
    </style>
  </head>
  <body>
    <div class="bg-glow-1"></div>
    <div class="bg-glow-2"></div>
    <div class="grid-bg"></div>
    <div class="stars"></div>

    <div class="content">
      <div class="left">
        <div class="badge">
          <span class="badge-dot"></span>
          Launching March 2026
        </div>

        <div class="wordmark">
          <span class="prof">prof</span><span class="claw">Claw</span>
        </div>

        <div class="tagline-sub">
          <span>prof</span> as in <em>professional</em>. <span>Claw</span> as in <em>grip</em>.
        </div>

        <div class="subtitle">Smart, lightweight AI agent engine</div>

        <div class="description">
          Run AI agents on your own hardware. Connect to Slack, Discord, Telegram - any chat app you already use.
        </div>

        <div class="stats">
          <div class="stat"><span class="stat-num">15+</span> Providers</div>
          <div class="stat"><span class="stat-num">65+</span> Tools</div>
          <div class="stat"><span class="stat-num">22+</span> Channels</div>
          <div class="stat"><span class="stat-num">MCP</span> Native</div>
        </div>
      </div>

      <div class="right">
        <div class="mascot-container">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="220" height="220">
            <defs>
              <linearGradient id="og-g" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fb7185" />
                <stop offset="100%" stop-color="#e11d48" />
              </linearGradient>
              <radialGradient id="og-shine" cx="0.4" cy="0.35" r="0.5">
                <stop offset="0%" stop-color="#fda4af" stop-opacity="0.3" />
                <stop offset="100%" stop-color="#fda4af" stop-opacity="0" />
              </radialGradient>
            </defs>
            <ellipse cx="50" cy="54" rx="24" ry="22" fill="url(#og-g)" />
            <ellipse cx="50" cy="54" rx="24" ry="22" fill="url(#og-shine)" />
            <ellipse cx="20" cy="54" rx="8" ry="6" fill="#be123c" />
            <ellipse cx="80" cy="54" rx="8" ry="6" fill="#be123c" />
            <path d="M15,49 L20,54 L25,49" stroke="#4c0519" stroke-width="1.8" fill="none" stroke-linecap="round" />
            <path d="M75,49 L80,54 L85,49" stroke="#4c0519" stroke-width="1.8" fill="none" stroke-linecap="round" />
            <rect x="39" y="73" width="8" height="10" rx="4" fill="#be123c" />
            <rect x="53" y="73" width="8" height="10" rx="4" fill="#be123c" />
            <line x1="39" y1="34" x2="31" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
            <circle cx="30" cy="18" r="3.5" fill="#fda4af" />
            <line x1="61" y1="34" x2="69" y2="20" stroke="#be123c" stroke-width="2.2" stroke-linecap="round" />
            <circle cx="70" cy="18" r="3.5" fill="#fda4af" />
            <circle cx="43" cy="51" r="6.5" fill="#fff" />
            <circle cx="57" cy="51" r="6.5" fill="#fff" />
            <circle cx="44.5" cy="50" r="3.5" fill="#4c0519" />
            <circle cx="58.5" cy="50" r="3.5" fill="#4c0519" />
            <circle cx="46" cy="48.5" r="1.4" fill="#fff" />
            <circle cx="60" cy="48.5" r="1.4" fill="#fff" />
            <path d="M45,63 Q50,68 57,62" stroke="#9f1239" stroke-width="2" fill="none" stroke-linecap="round" />
          </svg>
        </div>
      </div>
    </div>

    <div class="domain">profclaw.ai</div>
  </body>
</html>
